{
  "buildCommand": "npx expo export --platform web && cp public/index.html dist/landing.html",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/app", "destination": "/index.html" },
    { "source": "/app/(.*)", "destination": "/index.html" },
    { "source": "/", "destination": "/landing.html" }
  ]
}
