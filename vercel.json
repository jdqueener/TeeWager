{
  "buildCommand": "npx expo export --platform web && node scripts/copy-public.js",
  "outputDirectory": "dist",
  "routes": [
    { "src": "^/apple-touch-icon.png$", "dest": "/apple-touch-icon.png" },
    { "src": "^/favicon.ico$", "dest": "/apple-touch-icon.png" },
    { "src": "^/$", "dest": "/landing.html" },
    { "src": "^/partner$", "dest": "/partner.html" },
    { "src": "^/admin$", "dest": "/admin.html" },
    { "src": "^/portal$", "dest": "/portal.html" },
    { "src": "^/register$", "dest": "/partner.html" },
    { "src": "^/app$", "dest": "/index.html" },
    { "src": "^/app/(.*)$", "dest": "/index.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
