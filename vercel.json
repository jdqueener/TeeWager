{
  "buildCommand": "npx expo export --platform web && node -e \"const fs=require('fs');fs.copyFileSync('public/landing.html','dist/landing.html');fs.copyFileSync('public/partner.html','dist/partner.html');fs.copyFileSync('public/admin.html','dist/admin.html');\"",
  "outputDirectory": "dist",
  "routes": [
    { "src": "^/$", "dest": "/landing.html" },
    { "src": "^/partner$", "dest": "/partner.html" },
    { "src": "^/admin$", "dest": "/admin.html" },
    { "src": "^/app$", "dest": "/index.html" },
    { "src": "^/app/(.*)$", "dest": "/index.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
