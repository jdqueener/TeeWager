{
  "expo": {
    "name": "TeeWager",
    "slug": "TeeWager",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "teewager",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "TeeWager",
      "shortName": "TeeWager",
      "description": "Golf wagering made easy. Track beans, settle up, share results.",
      "lang": "en",
      "themeColor": "#1A4A2E",
      "backgroundColor": "#F0F4F0",
      "display": "standalone",
      "orientation": "portrait",
      "startUrl": "/",
      "scope": "/",
      "icon": "./assets/icon.png"
    },
    "plugins": [
      "expo-sharing",
      "expo-web-browser"
    ]
  }
}
